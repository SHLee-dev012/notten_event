# Caddy reverse proxy — automatic HTTPS (Let's Encrypt) + subdomain routing.
# Domains come from the environment (see deploy.env.example).
# Want cert-expiry notices? Add a global block:  { email you@example.com }

# Participant service
{$PARTICIPANT_DOMAIN} {
	encode zstd gzip
	reverse_proxy participant:3000
}

# Organizer service
{$ORGANIZER_DOMAIN} {
	encode zstd gzip
	reverse_proxy organizer:3001
}
