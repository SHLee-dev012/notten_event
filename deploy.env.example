# Docker Compose deployment settings.
# Copy to .env in the project root and edit:  cp deploy.env.example .env
# (docker compose reads .env automatically for ${VAR} substitution.)

# Image published by CI to GHCR. Pin a specific tag for reproducible deploys,
# e.g. ghcr.io/shlee-dev012/notten_event:sha-abc1234
NOTTEN_IMAGE=ghcr.io/shlee-dev012/notten_event:latest

# Domains the Caddy reverse proxy serves (must point at this host's IP).
# If unset, Caddy boots with local self-signed certs for localhost.
PARTICIPANT_DOMAIN=notten.example.com
ORGANIZER_DOMAIN=admin.notten.example.com

# The GHCR package is private by default. On the deploy host, either make the
# package public, or log in first:
#   echo <PAT-with-read:packages> | docker login ghcr.io -u <github-username> --password-stdin
